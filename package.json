{
  "name": "reflex-royale",
  "version": "1.0.0",
  "description": "Reflex Royale reaction game with a Next.js UI and Express/Socket.IO backend.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test tests/*.cjs",
    "test:visual": "npm run build && playwright test",
    "build": "next build",
    "render-build": "npm install --include=dev && npm run build",
    "render-start": "node server.js",
    "audio:extract": "node scripts/extract-audio-library.js",
    "audio:seed": "node scripts/seed-audio-library.js"
  },
  "keywords": [
    "nextjs",
    "express",
    "socket.io",
    "mongodb",
    "game"
  ],
  "author": "makinchii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makinchii/reflex-royale.git"
  },
  "bugs": {
    "url": "https://github.com/makinchii/reflex-royale/issues"
  },
  "homepage": "https://github.com/makinchii/reflex-royale#readme",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/fiber": "^9.6.1",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "connect-mongo": "^5.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "lucide-react": "^0.542.0",
    "mongoose": "^8.12.1",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "socket.io": "^4.8.3",
    "tailwind-merge": "^3.3.1",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@types/three": "^0.184.0",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.12",
    "shadcn": "^4.6.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
